{
  "name": "Sync README on Tool Changes",
  "version": "1.0.0",
  "description": "When new tools are added, remind to update the README features table",
  "when": {
    "type": "fileCreated",
    "patterns": ["kommo_mcp/tools/*.py"]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A new tool module was created. Update README.md features table and POWER.md 'Available Tools' section to include the new tool category."
  }
}
